# Server
ADDR=127.0.0.1:8080
APP_BASE_URL=http://127.0.0.1:8080
DATABASE_PATH=./storage/drifter.db
COOKIE_SECRET=dev-change-me-32-bytes-minimum
SECURE_COOKIES=false
SESSION_TTL_HOURS=12

# Development auth: accepts any username/password and marks users as project creators.
# Set false when LDAP_* is configured.
DEV_AUTH_ENABLED=true

# LDAP
LDAP_URL=ldaps://ldap.example.com:636
LDAP_BIND_DN=cn=drifter,ou=service,dc=example,dc=com
LDAP_BIND_PASSWORD=replace-me
LDAP_USER_BASE_DN=ou=users,dc=example,dc=com
LDAP_USER_FILTER=(uid=%s)
LDAP_GROUP_BASE_DN=ou=groups,dc=example,dc=com
LDAP_CREATOR_GROUPS=cn=drifter-creators,ou=groups,dc=example,dc=com

# Local source media: ingest input only, never browser playback.
SOURCE_ADAPTER=local
SOURCE_LOCAL_ROOT=./storage/source

# Local generated HLS: browser playback goes through authenticated Go routes.
HLS_ADAPTER=local
HLS_LOCAL_ROOT=./storage/hls
HLS_LOCAL_URL_PREFIX=/media/hls
HLS_PRESIGN_TTL_SECONDS=3600

# S3 source adapter (used when SOURCE_ADAPTER=s3)
SOURCE_S3_ENDPOINT=http://garage.local:3909
SOURCE_S3_REGION=garage
SOURCE_S3_BUCKET=drifter-source
SOURCE_S3_ROOT=
SOURCE_S3_ACCESS_KEY=
SOURCE_S3_SECRET_KEY=
SOURCE_S3_SESSION_TOKEN=

# S3 HLS adapter (used when HLS_ADAPTER=s3)
HLS_S3_ENDPOINT=http://garage.local:3909
HLS_S3_REGION=garage
HLS_S3_BUCKET=drifter-hls
HLS_S3_ROOT=
HLS_S3_ACCESS_KEY=
HLS_S3_SECRET_KEY=
HLS_S3_SESSION_TOKEN=

# FFmpeg
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
TRANSCODE_PROFILE_VERSION=poc-480p-v2
TRANSCODE_PRESET=ultrafast
HLS_SEGMENT_SECONDS=2
HLS_UPLOAD_WORKERS=8
INGEST_WORKERS=2
